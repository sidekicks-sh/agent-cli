{
  "name": "sidekick",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "sidekick": "./dist/sidekick"
  },
  "scripts": {
    "dev": "bun run ./apps/sidekick-cli/src/main.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build --compile --bytecode ./apps/sidekick-cli/src/main.ts --outfile ./dist/sidekick",
    "build:release": "bun run build && bun build --compile --target=bun-linux-x64 ./apps/sidekick-cli/src/main.ts --outfile ./dist/sidekick-linux-x64 && bun build --compile --target=bun-darwin-x64 ./apps/sidekick-cli/src/main.ts --outfile ./dist/sidekick-darwin-x64 && bun build --compile --target=bun-darwin-arm64 ./apps/sidekick-cli/src/main.ts --outfile ./dist/sidekick-darwin-arm64",
    "docker:smoke": "bash ./docker/smoke.sh",
    "release": "semantic-release",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.1",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
